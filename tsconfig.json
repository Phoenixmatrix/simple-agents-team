{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": ["bun-types"],
    "jsx": "react-jsx"
  },
  "references": [
    { "path": "packages/daemon" },
    { "path": "packages/dashboard" },
    { "path": "packages/db" },
    { "path": "packages/hooks" },
    { "path": "packages/px" },
    { "path": "packages/tracker" },
    { "path": "packages/tmux-manager" },
    { "path": "packages/workers" }
  ],
  "files": []
}
