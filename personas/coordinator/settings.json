{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(px *)",
      "Bash(echo $PX_AGENT_NAME)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks guard-dangerous"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px heartbeat"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks session-start"
          },
          {
            "type": "command",
            "command": "px hooks read-persona \"$(px personas coordinator)\""
          },
          {
            "type": "command",
            "command": "px hooks start-daemon"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks worker-busy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks worker-idle"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks worker-idle"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "px hooks session-end"
          }
        ]
      }
    ]
  }
}
